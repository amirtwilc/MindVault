<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="#E61A1A2E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="vertical"
        android:gravity="center"
        android:baselineAligned="false">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:gravity="center"
            android:text="MindVault"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            android:singleLine="true"
            android:includeFontPadding="false"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:baselineAligned="false">

        <TextView
            android:id="@+id/widget_new_note_btn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="+"
            android:textSize="24sp"
            android:textColor="#FFFFFFFF"
            android:includeFontPadding="false"/>

        <ImageView
            android:id="@+id/widget_new_jot_btn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_widget_bolt"
            android:contentDescription="@string/widget_jot_label"
            android:scaleType="centerInside"
            android:padding="6dp"/>

        <TextView
            android:id="@+id/widget_search_btn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="&#128269;"
            android:textSize="18sp"
            android:textColor="#CCFFFFFF"
            android:includeFontPadding="false"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Scrollable categories list — populated by CategoryWidgetService -->
    <ListView
        android:id="@+id/widget_categories_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="0dp"/>

</LinearLayout>
