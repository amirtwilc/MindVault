<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="#E61A1A2E">

    <!-- Header: Create + Search on left, MindVault (opens app) on right -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_new_note_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+"
            android:textSize="28sp"
            android:textColor="#FFFFFFFF"
            android:padding="4dp"/>

        <TextView
            android:id="@+id/widget_search_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#128269;"
            android:textSize="20sp"
            android:textColor="#CCFFFFFF"
            android:layout_marginStart="20dp"
            android:padding="4dp"/>

        <!-- Spacer pushes MindVault to the right regardless of widget width -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MindVault"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"/>

    </LinearLayout>

    <!-- Scrollable notes list — populated by NoteWidgetService/NoteWidgetFactory -->
    <ListView
        android:id="@+id/widget_notes_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="0dp"/>

</LinearLayout>
